function toast(msg) { const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2000); }

// === UNDO / REDO SYSTEM ===
const MAX_HISTORY = 50;
let undoStack = [];
let redoStack = [];
let isUndoRedo = false;
let lastSavedSnap = '';

function takeSnapshot() {
  return {
    input: document.getElementById('scriptInput').value,
    rules: JSON.parse(JSON.stringify(mergeRules)),
    exceptions: JSON.parse(JSON.stringify(mergeExceptions)),
    prevInput: prevInput
  };
}

function snapKey(snap) {
  return snap.input + '|' + JSON.stringify(snap.rules) + '|' + JSON.stringify(snap.exceptions);
}

function saveToUndo() {
  if (isUndoRedo) return;
  const snap = takeSnapshot();
  const key = snapKey(snap);
  if (key === lastSavedSnap) return;
  undoStack.push(snap);
  if (undoStack.length > MAX_HISTORY) undoStack.shift();
  redoStack = [];
  lastSavedSnap = key;
  updateUndoRedoButtons();
}

function applySnapshot(snap) {
  isUndoRedo = true;
  document.getElementById('scriptInput').value = snap.input;
  mergeRules = JSON.parse(JSON.stringify(snap.rules));
  mergeExceptions = JSON.parse(JSON.stringify(snap.exceptions));
  prevInput = snap.prevInput;
  processScript();
  lastSavedSnap = snapKey(snap);
  isUndoRedo = false;
  updateUndoRedoButtons();
}

function undo() {
  if (undoStack.length < 2) return;
  redoStack.push(undoStack.pop());
  const snap = undoStack[undoStack.length - 1];
  applySnapshot(snap);
}

function redo() {
  if (redoStack.length === 0) return;
  const snap = redoStack.pop();
  undoStack.push(snap);
  applySnapshot(snap);
}

function updateUndoRedoButtons() {
  document.getElementById('undoBtn').disabled = undoStack.length < 2;
  document.getElementById('redoBtn').disabled = redoStack.length === 0;
}

// Keyboard shortcuts
document.addEventListener('keydown', function(e) {
  if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
    e.preventDefault(); undo();
  } else if ((e.ctrlKey || e.metaKey) && e.key === 'z' && e.shiftKey) {
    e.preventDefault(); redo();
  } else if ((e.ctrlKey || e.metaKey) && e.key === 'y') {
    e.preventDefault(); redo();
  }
});

// On input: save before state, process, then save after state
function onInputChange() { saveToUndo(); processScript(); saveToUndo(); }
document.getElementById('scriptInput').addEventListener('input', onInputChange);
document.getElementById('maxChars').addEventListener('input', onInputChange);
document.getElementById('gapSec').addEventListener('input', onInputChange);
document.getElementById('punctMode').addEventListener('change', onInputChange);
document.getElementById('smartBreak').addEventListener('change', onInputChange);
</script>
