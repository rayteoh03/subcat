function buildCatSVG(variation) {
  const v = catVariations[variation];
  return catBase.before + v.face + catBase.after + (v.extras || '') + '</svg>';
}

function showExportOverlay(filename) {
  const overlay = document.getElementById('exportOverlay');
  const joke = exportJokes[Math.floor(Math.random() * exportJokes.length)];

  document.getElementById('exportMsg').textContent = joke.msg;
  document.getElementById('exportSub').textContent = filename + ' · ' + joke.sub;

  // Random cat variation
  const catIdx = Math.floor(Math.random() * catVariations.length);
  document.getElementById('bigCatContainer').innerHTML = buildCatSVG(catIdx);

  // Add sparkles
  document.querySelectorAll('.export-overlay .sparkle').forEach(s => s.remove());
  for (let i = 0; i < 6; i++) {
    const sp = document.createElement('span');
    sp.className = 'sparkle';
    sp.textContent = sparkleEmojis[Math.floor(Math.random() * sparkleEmojis.length)];
    sp.style.left = (15 + Math.random() * 70) + '%';
    sp.style.top = (15 + Math.random() * 70) + '%';
    sp.style.animationDelay = (Math.random() * 1.0) + 's';
    overlay.appendChild(sp);
  }

  overlay.classList.add('show');
  setTimeout(() => { overlay.classList.remove('show'); }, 3000);
}

function exportSRT() { if(!displayedLines.length){toast('🐱 No lines to export!');return;} const name=getFileName()+'.srt'; dl(genSRT(displayedLines),name,'text/plain'); showExportOverlay(name); }
function exportTXT() { if(!displayedLines.length){toast('🐱 No lines to export!');return;} const name=getFileName()+'.txt'; dl(displayedLines.join('\n'),name,'text/plain'); showExportOverlay(name); }
function copyLines() { if(!displayedLines.length){toast('🐱 Nothing to copy!');return;} navigator.clipboard.writeText(displayedLines.join('\n')).then(()=>showExportOverlay('clipboard')); }
function clearAll() { document.getElementById('scriptInput').value=''; mergeSelection=-1; displayedLines=[]; mergeRules=[]; mergeExceptions=[]; prevInput=''; mergedLineIndices=new Set(); displayToRawMap=[]; processScript(); }

const meows=['Meow!','Nyaa~','Miao~','\u55B5!','\u55B5\u55B5~','Purrr...','\uD83D\uDC1F?','Hewwo~','Mrrrp!'];
const idles=['Hi~!','...zzZ','\u2661','\u266A','meow?','nyaa','\u55B5~'];
function meow() {
  const cat = document.getElementById('floatingCat');
  const bubble = document.getElementById('catBubble');
  bubble.textContent = meows[Math.floor(Math.random()*meows.length)];
  cat.classList.add('clicked');
  cat.style.transform = 'scale(1.25) rotate(-8deg)';
  toast('\uD83D\uDC31 ' + bubble.textContent);
