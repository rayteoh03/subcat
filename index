<script>
// === PUNCTUATION PATTERNS ===
// Only strip sentence punctuation (commas, periods, exclamation, question, semicolon, colon, ellipsis)
// NOTE: 、(enumeration comma) is kept — it's used within sentences, not as a break
// NOTE: . is handled separately to preserve decimal points like 1.8
const CJK_STRIP = /[\uFF0C\u3002\uFF01\uFF1F\uFF1B\uFF1A\u2026]/g;
const ALL_STRIP_BASE = /[\uFF0C\u3002\uFF01\uFF1F\uFF1B\uFF1A\u2026,!?;:]/g;

// Punctuation that triggers line breaks (split AFTER these)
// No 、(enumeration), no . (could be decimal)
const BREAK_AFTER = new Set(['\uFF0C','\u3002','\uFF01','\uFF1F','\uFF1B','\uFF1A','\u2026',',',';',':','!','?']);

function isDecimalDot(text, idx) {
  // A dot is decimal if surrounded by digits: "1.8"
  if (text[idx] !== '.') return false;
  const before = idx > 0 && /[0-9]/.test(text[idx - 1]);
  const after = idx + 1 < text.length && /[0-9]/.test(text[idx + 1]);
  return before && after;
}

function stripPunct(text, mode) {
  if (mode === 'keep') return text;
  if (mode === 'strip-cjk') return text.replace(CJK_STRIP, '');
  // Strip ALL mode: use base pattern, then handle . separately (only strip non-decimal dots)
  let result = text.replace(ALL_STRIP_BASE, '');
  // Now strip standalone dots (not decimal)
  let out = '';
  for (let i = 0; i < result.length; i++) {
    if (result[i] === '.' && !isDecimalDot(result, i)) continue;
    out += result[i];
  }
  return out;
}

// === WIDTH CALCULATION ===
function isCJK(ch) {
  const c = ch.charCodeAt(0);
  return (c >= 0x4E00 && c <= 0x9FFF) || (c >= 0x3400 && c <= 0x4DBF) ||
         (c >= 0xF900 && c <= 0xFAFF) || (c >= 0x2E80 && c <= 0x2EFF) ||
         (c >= 0x3000 && c <= 0x303F) || (c >= 0xFF00 && c <= 0xFFEF) ||
         (c >= 0x300C && c <= 0x300F) || (c >= 0x300A && c <= 0x300B) ||
         (c >= 0x3010 && c <= 0x3011);
}

function charWidth(ch) {
  return isCJK(ch) ? 1 : 0.5;
}

function textWidth(str) {
  let w = 0;
  for (let i = 0; i < str.length; i++) w += charWidth(str[i]);
  return w;
}

// Width up to index (exclusive)
function widthUpTo(str, idx) {
  let w = 0;
  for (let i = 0; i < idx; i++) w += charWidth(str[i]);
  return w;
}

// Find char index where cumulative width reaches target
function indexAtWidth(str, targetW) {
  let w = 0;
  for (let i = 0; i < str.length; i++) {
    w += charWidth(str[i]);
    if (w > targetW) return i;
  }
  return str.length;
}

// === ENGLISH BLOCK DETECTION ===
function isLatin(ch) {
  const c = ch.charCodeAt(0);
  return (c >= 0x41 && c <= 0x5A) || (c >= 0x61 && c <= 0x7A) || (c >= 0x30 && c <= 0x39);
}

// Find English blocks: consecutive latin chars + spaces between them
function findEnglishBlocks(text) {
  const blocks = []; // [{start, end}]
  let i = 0;
  while (i < text.length) {
    if (isLatin(text[i])) {
      const start = i;
      while (i < text.length && (isLatin(text[i]) || (text[i] === ' ' && i + 1 < text.length && isLatin(text[i + 1])))) i++;
      blocks.push({ start, end: i });
    } else {
      i++;
    }
  }
  return blocks;
}

function isInsideEnglishBlock(idx, blocks) {
  for (const b of blocks) {
    if (idx > b.start && idx < b.end) return true;
  }
  return false;
}

// === BRACKET PROTECTION ===
function findProtectedRanges(text) {
  const PAIRS = [['(', ')'], ['\uFF08', '\uFF09'], ['\u300C', '\u300D'], ['\u300A', '\u300B']];
  const ranges = [];
  for (const [open, close] of PAIRS) {
    let i = 0;
    while (i < text.length) {
      const s = text.indexOf(open, i);
      if (s === -1) break;
      const e = text.indexOf(close, s + 1);
      if (e === -1) break;
      ranges.push([s, e]);
      i = e + 1;
    }
  }
  return ranges;
}

function isProtectedIdx(idx, ranges) {
  for (const [s, e] of ranges) {
    if (idx > s && idx <= e) return true;
  }
  return false;
}

// === SPLIT AT PUNCTUATION ===
function splitAtPunct(text) {
  const segments = [];
  let buf = '';
  for (let i = 0; i < text.length; i++) {
    buf += text[i];
    if (BREAK_AFTER.has(text[i])) {
      segments.push(buf);
      buf = '';
    }
  }
  if (buf) segments.push(buf);
  return segments;
}

// === SMART SPLIT WITH WIDTH, ENGLISH PROTECTION, BALANCING ===
function smartSplitLine(text, maxW) {
  const tw = textWidth(text);
  if (tw <= maxW) return [text];

  const engBlocks = findEnglishBlocks(text);
  const protRanges = findProtectedRanges(text);

  // Smart balance: if slightly over (up to 1.25x), split into two balanced halves
  if (tw <= maxW * 1.25) {
    const halfW = tw / 2;
    const midIdx = indexAtWidth(text, halfW);
    // Search around midIdx for a safe split point
    let bestSplit = midIdx;
    const searchRange = Math.max(3, Math.floor(text.length * 0.2));
    let bestDiff = Infinity;
    for (let i = Math.max(1, midIdx - searchRange); i <= Math.min(text.length - 1, midIdx + searchRange); i++) {
      if (isInsideEnglishBlock(i, engBlocks)) continue;
      if (isProtectedIdx(i, protRanges)) continue;
      const leftW = widthUpTo(text, i);
      const diff = Math.abs(leftW - halfW);
      if (diff < bestDiff) { bestDiff = diff; bestSplit = i; }
    }
    const l1 = text.slice(0, bestSplit).trim();
    const l2 = text.slice(bestSplit).trim();
    return [l1, l2].filter(l => l);
  }

  // Normal split for longer text
  const lines = [];
  let rem = text;
  let offset = 0;

  while (textWidth(rem) > maxW) {
    const cutIdx = indexAtWidth(rem, maxW);
    let sp = cutIdx;
    const minIdx = Math.max(1, Math.floor(cutIdx * 0.4));
    let found = false;

    // Look backwards for safe split: not inside English block or protected range
    for (let i = cutIdx - 1; i >= minIdx; i--) {
      if (isInsideEnglishBlock(offset + i, engBlocks)) continue;
      if (isProtectedIdx(offset + i, protRanges)) continue;
      // Prefer spaces
      if (rem[i] === ' ') { sp = i + 1; found = true; break; }
    }
    // If no space, find any safe position
    if (!found) {
      for (let i = cutIdx - 1; i >= minIdx; i--) {
        if (!isInsideEnglishBlock(offset + i, engBlocks) && !isProtectedIdx(offset + i, protRanges)) {
          sp = i; found = true; break;
        }
      }
    }
    // If still not found (long English block or bracket), look forward
    if (!found) {
      for (let i = cutIdx; i < rem.length; i++) {
        if (!isInsideEnglishBlock(offset + i, engBlocks) && !isProtectedIdx(offset + i, protRanges)) {
          sp = i; break;
        }
      }
    }

    lines.push(rem.slice(0, sp).trim());
    rem = rem.slice(sp);
    offset += sp;
  }
  if (rem.trim()) lines.push(rem.trim());
  return lines;
}

// === ENPS STRIPPING ===
function stripENPS(text) {
  return text
    .replace(/\{[^}]*\}/g, '')
    .replace(/<[^>]*>/g, '')
    .replace(/\[[^\]]*\]/g, '')
    .replace(/\(\([^)]*\)\)/g, '')
    .replace(/\s{2,}/g, ' ')
    .trim();
}

function processScript() {
  const raw = document.getElementById('scriptInput').value;
  const maxW = parseInt(document.getElementById('maxChars').value) || 18;
  const punctMode = document.getElementById('punctMode').value;
  const smart = document.getElementById('smartBreak').checked;
  document.getElementById('inputCount').textContent = raw.length + ' chars';
  mergeSelection = -1;

  // Detect if input is a continuation/edit (keep merges) vs completely replaced (reset)
  // Only reset merges when content is 90%+ different (essentially a fresh paste)
  const keepMerges = (function() {
    if (!prevInput) return false;
    if (!raw.trim()) return false;
    // Check how much of prevInput survives in raw using overlapping chunks
    const longer = prevInput.length > raw.length ? prevInput : raw;
    const shorter = prevInput.length > raw.length ? raw : prevInput;
    const chunkSize = Math.max(4, Math.floor(longer.length * 0.1));
    let matched = 0;
    const totalChunks = Math.floor(longer.length / chunkSize);
    for (let i = 0; i + chunkSize <= longer.length; i += chunkSize) {
      if (shorter.includes(longer.slice(i, i + chunkSize))) matched++;
    }
    const overlapRatio = totalChunks > 0 ? matched / totalChunks : 0;
    return overlapRatio > 0.1; // keep if more than 10% overlaps (reset only when 90%+ different)
  })();
  if (!keepMerges) {
    mergeRules = [];
    mergeExceptions = [];
  }
  prevInput = raw;

  if (!raw.trim()) {
    document.getElementById('preview').innerHTML = '<div class="empty-state"><svg class="pixel-cat" viewBox="0 0 16 16" width="48" height="48" style="opacity:0.3"><rect x="2" y="0" width="2" height="2" fill="#c4a890"/><rect x="12" y="0" width="2" height="2" fill="#c4a890"/><rect x="2" y="2" width="12" height="3" fill="#c4a890"/><rect x="1" y="3" width="14" height="4" fill="#c4a890"/><rect x="5" y="4" width="6" height="3" fill="#d9c4b0"/><rect x="4" y="4" width="2" height="2" fill="#9a7e6b"/><rect x="10" y="4" width="2" height="2" fill="#9a7e6b"/><rect x="7" y="5" width="2" height="1" fill="#c4a890"/><rect x="3" y="7" width="10" height="4" fill="#c4a890"/><rect x="5" y="8" width="6" height="3" fill="#d9c4b0"/><rect x="3" y="11" width="2" height="2" fill="#d9c4b0"/><rect x="11" y="11" width="2" height="2" fill="#d9c4b0"/></svg><p>Paste script on the left to preview ~</p></div>';
    updateStats([]);
    return [];
  }

  const paras = raw.split(/\n+/).filter(p => p.trim());
  let allLines = [];

  for (const p of paras) {
    const stripped = stripENPS(p.trim());
    if (!stripped) continue;

    if (smart) {
      const punctSegments = splitAtPunct(stripped);
      for (const seg of punctSegments) {
        const cleaned = stripPunct(seg, punctMode).replace(/\s+/g, ' ').trim();
        if (!cleaned) continue;
        if (textWidth(cleaned) <= maxW) {
          allLines.push(cleaned);
        } else {
          allLines.push(...smartSplitLine(cleaned, maxW));
        }
      }
    } else {
      const cleaned = stripPunct(stripped, punctMode).replace(/\s+/g, ' ').trim();
      if (!cleaned) continue;
      if (textWidth(cleaned) <= maxW) {
        allLines.push(cleaned);
      } else {
        allLines.push(...smartSplitLine(cleaned, maxW));
      }
    }
  }

  // Apply global merge rules (with local exceptions)
  mergedLineIndices = new Set();
  allLines = applyMergeRules(allLines);

  renderPreview(allLines, maxW);
  updateStats(allLines);
  return allLines;
}

// === MERGE SYSTEM ===
let mergeRules = [];
let mergeExceptions = [];
let prevInput = '';
let displayedLines = [];
let mergeSelection = -1;
let mergedLineIndices = new Set();

function ruleKey(a, b) { return a + '\u0000' + b; }

// Map from displayed line index to the raw line index where the merge happened
let displayToRawMap = []; // displayToRawMap[displayIdx] = rawIdx (for merged lines) or -1

function applyMergeRules(lines) {
  if (!mergeRules.length) {
    displayToRawMap = lines.map(() => -1);
    return lines;
  }
  const result = [];
  displayToRawMap = [];
  let i = 0;

  while (i < lines.length) {
    let wasMerged = false;
    if (i + 1 < lines.length) {
      for (const rule of mergeRules) {
        if (lines[i] === rule.a && lines[i + 1] === rule.b) {
          const isExcepted = mergeExceptions.some(ex => ex.a === rule.a && ex.b === rule.b && ex.rawIdx === i);
          if (!isExcepted) {
            result.push(lines[i] + lines[i + 1]);
            mergedLineIndices.add(result.length - 1);
            displayToRawMap.push(i); // this displayed line came from raw index i
            i += 2;
            wasMerged = true;
            break;
          }
        }
      }
    }
    if (!wasMerged) {
      result.push(lines[i]);
      displayToRawMap.push(-1); // not a merged line
      i++;
    }
  }
  return result;
}

// Store the raw (pre-merge) lines so we can map back for unmerge
let rawSplitLines = [];

function renderPreview(lines, maxW) {
  displayedLines = lines.slice();
  const el = document.getElementById('preview');
  if (!lines.length) { el.innerHTML = '<div class="empty-state"><p>No subtitle lines generated</p></div>'; return; }

  el.innerHTML = lines.map((l, i) => {
    const w = textWidth(l);
    const wDisplay = Math.ceil(w * 10) / 10;
    const cls = w > maxW ? 'over' : w > maxW - 1 ? 'warn' : 'ok';
    const isSelected = mergeSelection === i;
    const isMerged = mergedLineIndices.has(i);

    const btnIcon = isMerged ? '\u2212' : '+';
    const btnCls = 'sub-merge' + (isSelected ? ' selected' : '') + (isMerged ? ' merged' : '');
    const btnTitle = isMerged ? 'Unmerge this line' : 'Select to merge with adjacent line';

    return '<div class="sub-line' + (isMerged ? ' merged' : '') + '" data-idx="' + i + '">'
      + '<span class="sub-num">' + (i+1) + '</span>'
      + '<span class="sub-text">' + esc(l) + '</span>'
      + '<button class="' + btnCls + '" data-merge="' + i + '" title="' + btnTitle + '">' + btnIcon + '</button>'
      + '<span class="sub-count ' + cls + '">' + wDisplay + '</span>'
      + '</div>';
  }).join('');

  document.getElementById('lineCount').textContent = lines.length + ' lines';

  // Merge button click
  el.querySelectorAll('.sub-merge').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      const idx = parseInt(this.dataset.merge);
      if (mergedLineIndices.has(idx)) {
        handleUnmerge(idx);
      } else {
        handleMergeClick(idx);
      }
    });
  });

  // Single click line → navigate to source
  el.querySelectorAll('.sub-line').forEach(row => {
    row.addEventListener('click', function(e) {
      if (e.target.closest('.sub-merge')) return;
      const idx = parseInt(this.dataset.idx);
      navigateToSource(idx);
      el.querySelectorAll('.sub-line').forEach(r => r.classList.remove('active'));
      this.classList.add('active');
    });
  });
}

function handleMergeClick(idx) {
  if (mergeSelection === -1) {
    mergeSelection = idx;
    document.querySelectorAll('.sub-merge').forEach(b => b.classList.remove('selected'));
    const btn = document.querySelector('.sub-merge[data-merge="' + idx + '"]');
    if (btn) btn.classList.add('selected');
  } else if (mergeSelection === idx) {
    mergeSelection = -1;
    document.querySelectorAll('.sub-merge').forEach(b => b.classList.remove('selected'));
  } else {
    const a = Math.min(mergeSelection, idx);
    const b = Math.max(mergeSelection, idx);
    if (b - a === 1) {
      const lineA = displayedLines[a];
      const lineB = displayedLines[b];

      // Check if this pair matches an existing rule that has a local exception here
      // If so, just remove the exception (re-merge this instance only)
      let wasRemerge = false;
      for (const rule of mergeRules) {
        if (rule.a === lineA && rule.b === lineB) {
          // Find and remove the exception for this raw position
          // We need to figure out the raw index for displayedLines[a]
          // Since these are unmerged lines, they map 1:1 to raw positions
          // Walk displayToRawMap won't help since these aren't merged — need to reconstruct
          const rawLines = getRawSplitLines();
          // Find which raw index this displayed pair corresponds to
          // Count through raw lines, skipping merged ones, to find position of displayed line a
          let rawI = 0, dispI = 0;
          while (dispI < a && rawI < rawLines.length) {
            // Check if rawI is a merged pair (not excepted)
            let isMergedPair = false;
            if (rawI + 1 < rawLines.length) {
              for (const r of mergeRules) {
                if (rawLines[rawI] === r.a && rawLines[rawI + 1] === r.b) {
                  const isExc = mergeExceptions.some(ex => ex.a === r.a && ex.b === r.b && ex.rawIdx === rawI);
                  if (!isExc) { isMergedPair = true; break; }
                }
              }
            }
            if (isMergedPair) { rawI += 2; } else { rawI++; }
            dispI++;
          }

          // rawI now points to the raw index of displayed line a
          const exIdx = mergeExceptions.findIndex(ex => ex.a === rule.a && ex.b === rule.b && ex.rawIdx === rawI);
          if (exIdx !== -1) {
            mergeExceptions.splice(exIdx, 1);
            wasRemerge = true;
            break;
          }
        }
      }

      if (!wasRemerge) {
        // New merge rule (global)
        mergeRules.push({ a: lineA, b: lineB });
      }

      mergeSelection = -1;
      saveToUndo();
      processScript();
    } else {
      toast('🐱 Lines must be adjacent to merge!');
      mergeSelection = idx;
      document.querySelectorAll('.sub-merge').forEach(b => b.classList.remove('selected'));
      const btn = document.querySelector('.sub-merge[data-merge="' + idx + '"]');
      if (btn) btn.classList.add('selected');
    }
  }
}

function handleUnmerge(idx) {
  const mergedText = displayedLines[idx];
  const rawIdx = displayToRawMap[idx];

  // Find which rule produced this
  for (const rule of mergeRules) {
    if (rule.a + rule.b === mergedText) {
      // Add exception at the exact raw index this displayed line came from
      mergeExceptions.push({ a: rule.a, b: rule.b, rawIdx: rawIdx });
      saveToUndo();
      processScript();
      return;
    }
  }
}

function getRawSplitLines() {
  const raw = document.getElementById('scriptInput').value;
  const maxW = parseInt(document.getElementById('maxChars').value) || 18;
  const punctMode = document.getElementById('punctMode').value;
  const smart = document.getElementById('smartBreak').checked;
  const paras = raw.split(/\n+/).filter(p => p.trim());
  const lines = [];
  for (const p of paras) {
    const stripped = stripENPS(p.trim());
    if (!stripped) continue;
    if (smart) {
      for (const seg of splitAtPunct(stripped)) {
        const cleaned = stripPunct(seg, punctMode).replace(/\s+/g, ' ').trim();
        if (!cleaned) continue;
        if (textWidth(cleaned) <= maxW) lines.push(cleaned);
        else lines.push(...smartSplitLine(cleaned, maxW));
      }
    } else {
      const cleaned = stripPunct(stripped, punctMode).replace(/\s+/g, ' ').trim();
      if (!cleaned) continue;
      if (textWidth(cleaned) <= maxW) lines.push(cleaned);
      else lines.push(...smartSplitLine(cleaned, maxW));
    }
  }
  return lines;
}

function navigateToSource(idx) {
  const ta = document.getElementById('scriptInput');
  const raw = ta.value;
  const lineText = displayedLines[idx];
  if (!lineText || !raw) return;

  // If this is a merged line, find the original two parts
  let partA = null, partB = null;
  if (mergedLineIndices.has(idx)) {
    for (const rule of mergeRules) {
      if (rule.a + rule.b === lineText) {
        partA = rule.a;
        partB = rule.b;
        break;
      }
    }
  }

  let startPos = -1;
  let endPos = -1;

  if (partA && partB) {
    // Merged line: find partA start, then find partB end after it
    startPos = findInRaw(raw, partA, 0);
    if (startPos !== -1) {
      // Search for partB starting from after partA's position
      const searchFrom = startPos + partA.length;
      // Look within a reasonable range (there might be punctuation between the two parts)
      const endSearch = Math.min(raw.length, searchFrom + partB.length + 20);
      const bPos = findInRaw(raw, partB, searchFrom);
      if (bPos !== -1) {
        endPos = bPos + partB.length;
      } else {
        endPos = searchFrom + partA.length;
      }
    }
  }

  // Non-merged or fallback
  if (startPos === -1) {
    startPos = findInRaw(raw, lineText, 0);
    if (startPos !== -1) {
      endPos = startPos + lineText.length;
    }
  }

  // Final fallback: progressive shorter chunks
  if (startPos === -1) {
    const tryLengths = [12, 8, 5, 3];
    for (const len of tryLengths) {
      if (len > lineText.length) continue;
      const chunk = lineText.slice(0, len);
      const found = raw.indexOf(chunk);
      if (found !== -1) { startPos = found; endPos = found + chunk.length; break; }
    }
  }

  // Fuzzy fallback
  if (startPos === -1) {
    const target = lineText.slice(0, Math.min(lineText.length, 6));
    let ti = 0;
    for (let ri = 0; ri < raw.length && ti < target.length; ri++) {
      if (raw[ri] === target[ti]) { if (ti === 0) startPos = ri; ti++; }
    }
    if (ti >= target.length) { endPos = startPos + target.length; }
    else { startPos = 0; endPos = 0; }
  }

  if (startPos === -1) { startPos = 0; endPos = 0; }

  ta.focus();
  ta.setSelectionRange(startPos, endPos);
  const lineHeight = parseFloat(getComputedStyle(ta).lineHeight) || 24;
  const newlines = (raw.slice(0, startPos).match(/\n/g) || []).length;
  ta.scrollTop = Math.max(0, newlines * lineHeight - ta.clientHeight / 3);
}

// Helper: find text in raw, starting from offset, skipping punctuation gaps
function findInRaw(raw, text, fromIdx) {
  // Try exact match first
  const exact = raw.indexOf(text, fromIdx);
  if (exact !== -1) return exact;

  // Try first few chars
  const tryLens = [Math.min(text.length, 8), Math.min(text.length, 5), Math.min(text.length, 3)];
  for (const len of tryLens) {
    const chunk = text.slice(0, len);
    if (chunk.length < 2) continue;
    const found = raw.indexOf(chunk, fromIdx);
    if (found !== -1) return found;
  }

  return -1;
}

function updateStats(lines) {
  const t = lines.length, maxW = parseInt(document.getElementById('maxChars').value) || 18;
  const gap = parseFloat(document.getElementById('gapSec').value) || 3;
  const over = lines.filter(l => textWidth(l) > maxW).length;
  const avg = t ? (lines.reduce((s, l) => s + textWidth(l), 0) / t).toFixed(1) : 0;
  const d = t * gap;
  document.getElementById('statLines').textContent = t;
  document.getElementById('statOver').textContent = over;
  document.getElementById('statAvg').textContent = avg;
  document.getElementById('statDuration').textContent = pad(Math.floor(d/3600)) + ':' + pad(Math.floor(d%3600/60)) + ':' + pad(Math.floor(d%60));
}

function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function pad(n) { return String(n).padStart(2,'0'); }

function parseTC(tc) {
  const m = tc.match(/(\d+):(\d+):(\d+)[,.](\d+)/);
  return m ? +m[1]*3600000 + +m[2]*60000 + +m[3]*1000 + +m[4] : 0;
}
function fmtTC(ms) {
  const h = Math.floor(ms/3600000); ms %= 3600000;
  const m = Math.floor(ms/60000); ms %= 60000;
  const s = Math.floor(ms/1000);
  return pad(h)+':'+pad(m)+':'+pad(s)+','+String(ms%1000).padStart(3,'0');
}

function genSRT(lines) {
  const gap = (parseFloat(document.getElementById('gapSec').value)||3)*1000;
  let st = parseTC(document.getElementById('startTC').value)||1000;
  return lines.map((l,i) => { const e=st+gap; const r=(i+1)+'\n'+fmtTC(st)+' --> '+fmtTC(e)+'\n'+l+'\n'; st=e; return r; }).join('\n');
}

