// Feed the cat - drag fish to cat
const eatReactions=['\u55B5\uFF01\u597D\u5403\uFF01','Yummy!','Om nom nom!','\u55B5~\u8C22\u8C22!','\u2661 \u2661 \u2661','\u597D\u9999\uFF01','More pls!','\u55B5\u55B5\u55B5~','*munch*','*chomp*'];
let feedCooldown = false;
let isDragging = false;
let dragOffsetX = 0, dragOffsetY = 0;

function randomFishPos() {
  // Use the .app container to stay within content bounds
  const app = document.querySelector('.app');
  const appRect = app.getBoundingClientRect();
  const fishW = 36; // fish svg width
  const minX = appRect.left + 10;
  const maxX = appRect.right - fishW - 10;
  const catLeft = 30, catRight = 130; // cat zone to avoid
  let x;
  let tries = 0;
  do {
    x = minX + Math.floor(Math.random() * (maxX - minX));
    tries++;
  } while (x > catLeft && x < catRight && tries < 20);
  return Math.max(minX, Math.min(x, maxX));
}

// Initial random position
(function initFish() {
  const fish = document.getElementById('deadFish');
  fish.style.left = randomFishPos() + 'px';
})();

// Reposition fish on resize so it stays in view
window.addEventListener('resize', function() {
  const fish = document.getElementById('deadFish');
  if (!isDragging && !fish.classList.contains('grabbed')) {
    resetFishPos(fish);
  }
});

function getPos(e) {
  if (e.touches) return { x: e.touches[0].clientX, y: e.touches[0].clientY };
  return { x: e.clientX, y: e.clientY };
}

function startDrag(e) {
  if (feedCooldown) return;
  e.preventDefault();
  const fish = document.getElementById('deadFish');
  const rect = fish.getBoundingClientRect();
  const pos = getPos(e);
  dragOffsetX = pos.x - rect.left;
  dragOffsetY = pos.y - rect.top;
  isDragging = true;
  fish.classList.add('dragging');
  // Switch to top/left positioning for free movement
  fish.style.bottom = 'auto';
  fish.style.top = rect.top + 'px';
  fish.style.left = rect.left + 'px';
}

function onDrag(e) {
  if (!isDragging) return;
  e.preventDefault();
  const fish = document.getElementById('deadFish');
  const pos = getPos(e);
  fish.style.left = (pos.x - dragOffsetX) + 'px';
  fish.style.top = (pos.y - dragOffsetY) + 'px';
}

function endDrag(e) {
  if (!isDragging) return;
  isDragging = false;
  const fish = document.getElementById('deadFish');
  fish.classList.remove('dragging');

  // Check if fish overlaps with cat
  const fishRect = fish.getBoundingClientRect();
  const catRect = document.getElementById('floatingCat').getBoundingClientRect();

  const fishCX = fishRect.left + fishRect.width / 2;
  const fishCY = fishRect.top + fishRect.height / 2;

  // Hit zone: within ~40px of cat center
  const catCX = catRect.left + catRect.width / 2;
  const catCY = catRect.top + catRect.height / 2;
  const dist = Math.sqrt((fishCX - catCX) ** 2 + (fishCY - catCY) ** 2);

  if (dist < 55) {
    // Fed the cat!
    triggerEat(fish);
  } else {
    // Snap back to ground
    resetFishPos(fish);
  }
}

function triggerEat(fish) {
  feedCooldown = true;
  const cat = document.getElementById('floatingCat');
  const bubble = document.getElementById('catBubble');

  fish.classList.add('grabbed');

  setTimeout(() => {
    cat.classList.add('eating');
    bubble.textContent = eatReactions[Math.floor(Math.random() * eatReactions.length)];
    bubble.style.transform = 'translateX(-50%) scale(1)';
    bubble.style.opacity = '1';
    toast('\uD83D\uDC31 ' + bubble.textContent);
  }, 150);

  setTimeout(() => {
    cat.classList.remove('eating');
    bubble.style.transform = '';
    bubble.style.opacity = '';
    fish.classList.remove('grabbed');
    resetFishPos(fish);
    feedCooldown = false;
  }, 3200);
}

function resetFishPos(fish) {
  fish.style.top = '';
  fish.style.bottom = '40px';
  fish.style.left = randomFishPos() + 'px';
}

// Mouse events
const fishEl = document.getElementById('deadFish');
fishEl.addEventListener('mousedown', startDrag);
document.addEventListener('mousemove', onDrag);
document.addEventListener('mouseup', endDrag);
// Touch events
fishEl.addEventListener('touchstart', startDrag, { passive: false });
